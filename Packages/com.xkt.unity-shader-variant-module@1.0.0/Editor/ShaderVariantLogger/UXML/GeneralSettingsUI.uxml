<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="GeneralConfig" style="flex-shrink: 0;">
        <ui:Label text="编辑器中的着色器编译日志" display-tooltip-when-elided="true" />
        <ui:Toggle label="启用" name="LoggerEnable" style="margin-left: 15px;" />
        <ui:Foldout text="高级" value="true" style="margin-left: 15px;">
            <ui:Toggle label="启动时清理着色器缓存" tooltip="首次抓取时建议启用" name="ClearShaderCache" style="margin-left: 15px;" />
            <ui:TextField label="文件名的头" name="FileHeader" picking-mode="Ignore" style="margin-left: 15px;" />
        </ui:Foldout>
    </ui:VisualElement>
    <ui:VisualElement style="height: 10px; flex-shrink: 0;" />
    <ui:VisualElement name="LogArea" style="flex-shrink: 0;">
        <ui:VisualElement style="flex-wrap: nowrap; flex-direction: row; justify-content: space-between;">
            <ui:Label text="日志" display-tooltip-when-elided="true" />
            <ui:Button text="打开目录" name="OpenDir" display-tooltip-when-elided="true" style="align-items: stretch; justify-content: space-between; flex-direction: row; flex-wrap: nowrap; white-space: nowrap; -unity-text-align: middle-center;" />
            <ui:Button text="清除日志" parse-escape-sequences="false" display-tooltip-when-elided="true" name="ClearLogs" style="-unity-text-align: middle-center; align-items: stretch; flex-direction: row; justify-content: space-between;" />
        </ui:VisualElement>
        <ui:ScrollView name="LogList" style="margin-left: 20px;" />
    </ui:VisualElement>
</ui:UXML>
